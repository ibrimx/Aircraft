{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@aircraft/shared-types": [
        "./packages/shared-types/dist"
      ],
      "@aircraft/studio-engine": [
        "./packages/studio-engine/dist"
      ],
      "@aircraft/builder-engine": [
        "./packages/builder-engine/dist"
      ],
      "@aircraft/cms-engine": [
        "./packages/cms-engine/dist"
      ],
      "@aircraft/auth-engine": [
        "./packages/auth-engine/dist"
      ],
      "@aircraft/fabric-adapter": [
        "./packages/fabric-adapter/dist"
      ],
      "@aircraft/mobile-runtime": [
        "./packages/mobile-runtime/dist"
      ],
      "@aircraft/brand-kit": [
        "./packages/brand-kit/dist"
      ],
      "@aircraft/state-bridge": [
        "./packages/state-bridge/dist"
      ],
      "@aircraft/local-draft": [
        "./packages/local-draft/dist"
      ],
      "@aircraft/sync-engine": [
        "./packages/sync-engine/dist"
      ],
      "@aircraft/error-boundary": [
        "./packages/error-boundary/dist"
      ],
      "@aircraft/storage-adapter": [
        "./packages/storage-adapter/dist"
      ],
      "@aircraft/publish-adapters": [
        "./packages/publish-adapters/dist"
      ],
      "@aircraft/a11y": [
        "./packages/a11y/dist"
      ],
      "@aircraft/ui": [
        "./packages/ui/dist"
      ],
      "@aircraft/design-tokens": [
        "./packages/design-tokens/dist"
      ]
    }
  }
}

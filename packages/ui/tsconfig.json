{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": [
      "react",
      "react-dom",
      "node"
    ],
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@aircraft/ui": [
        "./src/index.ts"
      ],
      "@aircraft/ui/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}

{
  "name": "@aircraft/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "next build",
    "start": "next start",
    "pages:build": "pnpm --filter @aircraft/shared-types build && pnpm --filter @aircraft/design-tokens build && pnpm --filter @aircraft/fabric-adapter build && pnpm --filter @aircraft/state-bridge build && pnpm --filter @aircraft/builder-engine build && pnpm --filter @aircraft/ui build && pnpm --filter @aircraft/web build:cf",

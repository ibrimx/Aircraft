    "pages:deploy": "pnpm pages:build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings=0",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "next": "^15.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@aircraft/shared-types": "workspace:*",

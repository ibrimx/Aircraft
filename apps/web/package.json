{
  "name": "@aircraft/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "next-on-pages",
    "pages:build": "pnpm --filter @aircraft/shared-types build && pnpm --filter @aircraft/design-tokens build && pnpm --filter @aircraft/ui build && pnpm --filter @aircraft/web build:cf",
    "preview": "wrangler pages dev .vercel/output/static",
    "lint": "next lint",
    "postbuild": "rm -rf .next/cache || true && rm -rf cache || true && rm -rf .vercel/output/static/cache || true && rm -rf .vercel/output/static/cache/webpack || true && find .vercel/output -type d -path \"*/cache/webpack\" -prune -exec rm -rf {} + 2>/dev/null || true"
  },
  "dependencies": {
    "@aircraft/design-tokens": "workspace:*",
    "@aircraft/shared-types": "workspace:*",
    "@aircraft/ui": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.3",
    "i18next": "^25.5.2",
    "lucide-react": "^0.576.0",
    "next": "^15.5.2",
    "postcss": "^8.5.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.7.3",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "tailwind-merge": "^3.5.0",
    "wrangler": "^3.101.0"
  }
}
